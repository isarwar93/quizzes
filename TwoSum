import numpy as np
class Solution(object):
    def twoSum(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        
        for i in np.arange(0,len(nums)):
           for j in np.arange(i+1,len(nums)): 
             sum = nums[i]+nums[j] 
             if sum == target:
                l,m = i,j
                return [l,m]
                 
             
        
